<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Savanna" parent="Theme.Material3.Dark.NoActionBar">
        <!-- OLED black everywhere -->
        <item name="colorPrimary">#FFFFFFFF</item>
        <item name="colorPrimaryDark">#FF000000</item>
        <item name="colorAccent">#FFFFFFFF</item>
        <item name="colorOnPrimary">#FF000000</item>
        <item name="colorSecondary">#FF8E8E93</item>
        <item name="colorOnSecondary">#FF000000</item>
        <item name="colorSurface">#FF0A0A0A</item>
        <item name="colorOnSurface">#FFFFFFFF</item>
        <item name="android:colorBackground">#FF000000</item>
        <item name="android:windowBackground">#FF000000</item>
        <item name="android:statusBarColor">#FF000000</item>
        <item name="android:navigationBarColor">#FF000000</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- SF Pro: place SF-Pro-Text-Regular.ttf etc in res/font/ and
             set android:fontFamily="@font/sf_pro" to activate system-wide -->
    </style>

    <!--
      Glass BottomSheet theme — TabSwitcherFragment (BottomSheetDialogFragment)
      Transparent sheet background so our glass drawable shows through.
      Light dim because blur-behind handles the visual depth on API 31+.
    -->
    <style name="GlassBottomSheetDialog" parent="Theme.Material3.BottomSheetDialog">
        <item name="android:backgroundDimAmount">0.28</item>
        <item name="bottomSheetStyle">@style/GlassBottomSheetStyle</item>
        <item name="android:windowIsFloating">false</item>
    </style>

    <style name="GlassBottomSheetStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="GlassCard">
        <item name="android:background">@drawable/glass_background</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="UrlBarStyle">
        <item name="android:background">@drawable/url_bar_background</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:imeOptions">actionGo</item>
        <item name="android:inputType">textUri</item>
    </style>

    <style name="NavButton">
        <item name="android:background">@drawable/button_background</item>
        <item name="android:padding">9dp</item>
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:scaleType">centerInside</item>
    </style>

    <style name="SectionTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>
</resources>
