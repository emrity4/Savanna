<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Savanna" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#FF7C3AED</item>
        <item name="colorPrimaryDark">#FF6D28D9</item>
        <item name="colorAccent">#FF7C3AED</item>
        <item name="colorOnPrimary">#FFFFFFFF</item>
        <item name="colorSecondary">#FF8E8E93</item>
        <item name="colorOnSecondary">#FFFFFFFF</item>
        <item name="colorSurface">#FFFFFFFF</item>
        <item name="colorOnSurface">#FF000000</item>
        <item name="android:colorBackground">#FFF2F2F7</item>
        <item name="android:windowBackground">#FFF2F2F7</item>
        <item name="android:statusBarColor">#FFF2F2F7</item>
        <item name="android:navigationBarColor">#FFF2F2F7</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="GlassBottomSheetDialog" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="android:backgroundDimAmount">0.28</item>
        <item name="bottomSheetStyle">@style/GlassBottomSheetStyle</item>
        <item name="android:windowIsFloating">false</item>
    </style>

    <style name="GlassBottomSheetStyle" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="GlassCard">
        <item name="android:background">@drawable/glass_background</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="UrlBarStyle">
        <item name="android:background">@drawable/url_bar_background</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:imeOptions">actionGo</item>
        <item name="android:inputType">textUri</item>
    </style>

    <style name="NavButton">
        <item name="android:background">@drawable/button_background</item>
        <item name="android:padding">9dp</item>
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:scaleType">centerInside</item>
    </style>

    <style name="SectionTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>
</resources>
