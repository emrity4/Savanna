<?xml version="1.0" encoding="utf-8"?>
<!--
  Liquid Glass Menu Item - iOS 26 Specification
  ============================================
  Face Tint:  White 12% opacity
  Border:     1.5dp gradient stroke
  Inner Glow: Top highlight
  Radius:     14dp
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#33FFFFFF">
    <item>
        <layer-list>
            <!-- LAYER 1: Base Dark Underlay -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#B0000000" />
                    <corners android:radius="14dp" />
                </shape>
            </item>

            <!-- LAYER 2: Face Tint (12% White) -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#1EFFFFFF" />
                    <corners android:radius="14dp" />
                </shape>
            </item>

            <!-- LAYER 3: Directional Gradient -->
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="315"
                        android:startColor="#33FFFFFF"
                        android:endColor="#08FFFFFF" />
                    <corners android:radius="14dp" />
                </shape>
            </item>

            <!-- LAYER 4: Inner Top Highlight (1dp) -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#66FFFFFF" />
                    <corners android:topLeftRadius="14dp" android:topRightRadius="14dp" />
                    <padding android:top="1dp" />
                </shape>
            </item>

            <!-- LAYER 5: Gradient Border (1.5dp) -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#00000000" />
                    <stroke
                        android:width="1.5dp"
                        android:color="#2AFFFFFF" />
                    <corners android:radius="14dp" />
                </shape>
            </item>

            <!-- LAYER 6: Top-Left Edge Catch Light (0.5dp) -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#00000000" />
                    <stroke
                        android:width="0.5dp"
                        android:color="#66FFFFFF" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
