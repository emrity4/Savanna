<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#44FFFFFF">
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#1FFFFFFF" />
                    <corners android:radius="20dp" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:type="linear" android:angle="315"
                        android:startColor="#40FFFFFF" android:endColor="#08FFFFFF" />
                    <corners android:radius="20dp" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#00000000" />
                    <stroke android:width="0.75dp" android:color="#30FFFFFF" />
                    <corners android:radius="20dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
