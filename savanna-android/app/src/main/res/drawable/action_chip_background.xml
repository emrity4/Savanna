<?xml version="1.0" encoding="utf-8"?>
<!--
  Liquid Glass Action Chip - iOS 26 Specification
  ============================================
  Face Tint:  White 15% opacity
  Border:     1.5dp gradient (TL: White 50% -> BR: White 10%)
  Inner Glow: Top highlight
  Radius:     20dp (pill shape)
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#44FFFFFF">
    <item>
        <layer-list>
            <!-- LAYER 1: Base Dark Underlay -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#D9000000" />
                    <corners android:radius="20dp" />
                </shape>
            </item>

            <!-- LAYER 2: Face Tint (15% White) -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#26FFFFFF" />
                    <corners android:radius="20dp" />
                </shape>
            </item>

            <!-- LAYER 3: Directional Gradient -->
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="315"
                        android:startColor="#40FFFFFF"
                        android:endColor="#08FFFFFF" />
                    <corners android:radius="20dp" />
                </shape>
            </item>

            <!-- LAYER 4: Inner Top Highlight (1dp) -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#73FFFFFF" />
                    <corners android:topLeftRadius="20dp" android:topRightRadius="20dp" />
                    <padding android:top="1dp" />
                </shape>
            </item>

            <!-- LAYER 5: Gradient Border (1.5dp) -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#00000000" />
                    <stroke
                        android:width="1.5dp"
                        android:color="#33FFFFFF" />
                    <corners android:radius="20dp" />
                </shape>
            </item>

            <!-- LAYER 6: Top-Left Edge Catch Light (0.5dp) -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#00000000" />
                    <stroke
                        android:width="0.5dp"
                        android:color="#80FFFFFF" />
                    <corners android:radius="20dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
