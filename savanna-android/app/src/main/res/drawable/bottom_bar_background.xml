<?xml version="1.0" encoding="utf-8"?>
<!-- Liquid Glass bottom bar — floating dock style -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#C8000000" />
            <corners android:topLeftRadius="20dp" android:topRightRadius="20dp" />
        </shape>
    </item>
    <!-- White frosted overlay -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0DFFFFFF" />
            <corners android:topLeftRadius="20dp" android:topRightRadius="20dp" />
        </shape>
    </item>
    <!-- Top specular gradient -->
    <item android:bottom="80%">
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="270"
                android:startColor="#20FFFFFF" android:endColor="#00FFFFFF" />
            <corners android:topLeftRadius="20dp" android:topRightRadius="20dp" />
        </shape>
    </item>
    <!-- Top edge highlight line -->
    <item android:bottom="97%">
        <shape android:shape="rectangle">
            <solid android:color="#28FFFFFF" />
            <corners android:topLeftRadius="20dp" android:topRightRadius="20dp" />
        </shape>
    </item>
</layer-list>
