<?xml version="1.0" encoding="utf-8"?>
<!--
  Safari iOS 26 URL bar — larger glass pill, more opaque
  Identical to url_bar_background but with 16dp radius for pill shape
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#D0000000" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#14FFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item android:bottom="50%">
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="270"
                android:startColor="#1CFFFFFF" android:endColor="#00FFFFFF" />
            <corners android:topLeftRadius="16dp" android:topRightRadius="16dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="0.5dp" android:color="#30FFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
