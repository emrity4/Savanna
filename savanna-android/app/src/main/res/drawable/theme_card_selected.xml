<?xml version="1.0" encoding="utf-8"?>
<!--
  Liquid Glass Theme Card (Selected) - iOS 26 Specification
  ============================================
  Face Tint:  Accent color (Purple) at 20% opacity
  Border:     2dp gradient stroke (accent color)
  Inner Glow: Top highlight (accent-tinted)
  Radius:     16dp
  Active glow: Purple tint bleed
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- LAYER 1: Base Dark Underlay -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#D9000000" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- LAYER 2: Accent Tint (Purple at 20% opacity) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#33B6A8FF" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- LAYER 3: Directional Gradient (accent-tinted) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="315"
                android:startColor="#59B6A8FF"
                android:endColor="#14B6A8FF" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- LAYER 4: Inner Top Highlight (1.5dp, accent-tinted) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#80B6A8FF" />
            <corners android:topLeftRadius="16dp" android:topRightRadius="16dp" />
            <padding android:top="1.5dp" />
        </shape>
    </item>

    <!-- LAYER 5: Accent Border (2dp) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="2dp"
                android:color="#B6A8FF" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- LAYER 6: Top-Left Edge Catch Light (1dp) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="1dp"
                android:color="#E6B6A8FF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
