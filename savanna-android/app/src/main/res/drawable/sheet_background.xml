<?xml version="1.0" encoding="utf-8"?>
<!--
  iOS 26 Liquid Glass overlay sheet — slides up from bottom.
  Strong specular at the rounded top edge (the "lip" of the glass sheet).
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 1. Near-opaque dark glass base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F0000000" />
            <corners android:topLeftRadius="28dp" android:topRightRadius="28dp" />
        </shape>
    </item>

    <!-- 2. Frosted white tint -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#18FFFFFF" />
            <corners android:topLeftRadius="28dp" android:topRightRadius="28dp" />
        </shape>
    </item>

    <!-- 3. Broad specular sweep — top 20% of sheet -->
    <item android:bottom="80%">
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="270"
                android:startColor="#40FFFFFF" android:endColor="#00FFFFFF" />
            <corners android:topLeftRadius="28dp" android:topRightRadius="28dp" />
        </shape>
    </item>

    <!-- 4. Hot specular peak — top 8% -->
    <item android:bottom="92%">
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="270"
                android:startColor="#55FFFFFF" android:endColor="#00FFFFFF" />
            <corners android:topLeftRadius="28dp" android:topRightRadius="28dp" />
        </shape>
    </item>

    <!-- 5. Top-edge specular line (the thinnest brightest highlight) -->
    <item android:bottom="98.5%">
        <shape android:shape="rectangle">
            <solid android:color="#72FFFFFF" />
            <corners android:topLeftRadius="28dp" android:topRightRadius="28dp" />
        </shape>
    </item>

</layer-list>
