<?xml version="1.0" encoding="utf-8"?>
<!--
  Liquid Glass Sheet Background - iOS 26 Specification
  ============================================
  Face Tint:  White 14% opacity
  Border:     1.5dp gradient stroke (top corners only)
  Inner Glow: Top highlight
  Radius:     28dp (top corners only)
  Shadow:     Black 6%, 16dp radius, 8dp Y-offset
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- LAYER 1: Ambient Shadow -->
    <item android:top="0dp" android:bottom="8dp" android:left="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#0F000000" />
            <corners android:topLeftRadius="28dp" android:topRightRadius="28dp" />
        </shape>
    </item>

    <!-- LAYER 2: Base Dark Underlay -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F2000000" />
            <corners android:topLeftRadius="28dp" android:topRightRadius="28dp" />
        </shape>
    </item>

    <!-- LAYER 3: Face Tint (14% White) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#24FFFFFF" />
            <corners android:topLeftRadius="28dp" android:topRightRadius="28dp" />
        </shape>
    </item>

    <!-- LAYER 4: Directional Gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="315"
                android:startColor="#4DFFFFFF"
                android:endColor="#0DFFFFFF" />
            <corners android:topLeftRadius="28dp" android:topRightRadius="28dp" />
        </shape>
    </item>

    <!-- LAYER 5: Inner Top Highlight (1.5dp) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#73FFFFFF" />
            <corners android:topLeftRadius="28dp" android:topRightRadius="28dp" />
            <padding android:top="1.5dp" />
        </shape>
    </item>

    <!-- LAYER 6: Gradient Border (1.5dp) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="1.5dp"
                android:color="#33FFFFFF" />
            <corners android:topLeftRadius="28dp" android:topRightRadius="28dp" />
        </shape>
    </item>

    <!-- LAYER 7: Top-Left Edge Catch Light (0.5dp) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="0.5dp"
                android:color="#80FFFFFF" />
            <corners android:topLeftRadius="28dp" android:topRightRadius="28dp" />
        </shape>
    </item>
</layer-list>
