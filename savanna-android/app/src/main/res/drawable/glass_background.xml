<?xml version="1.0" encoding="utf-8"?>
<!-- Liquid Glass card background -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#B8000000" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- White frosted overlay -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#10FFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Specular diagonal -->
    <item android:bottom="55%">
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="270"
                android:startColor="#18FFFFFF" android:endColor="#00FFFFFF" />
            <corners android:topLeftRadius="16dp" android:topRightRadius="16dp" />
        </shape>
    </item>
    <!-- Border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="0.5dp" android:color="#25FFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
