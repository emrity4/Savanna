<?xml version="1.0" encoding="utf-8"?>
<!-- Liquid Glass History Sheet -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/sheet_background">

    <!-- Drag handle pill -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="6dp"
        android:background="#40FFFFFF"
        android:layout_marginStart="0dp" />

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:paddingStart="22dp"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:text="@string/history"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_clear_history"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_delete"
                android:background="@drawable/button_background"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:alpha="0.7"
                android:contentDescription="@string/clear_history" />

            <ImageView
                android:id="@+id/btn_close_history"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_close"
                android:background="@drawable/button_background"
                android:padding="9dp"
                android:scaleType="centerInside"
                android:layout_marginStart="4dp"
                android:contentDescription="@string/done" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Glass search bar -->
    <EditText
        android:id="@+id/search_history"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        style="@style/UrlBarStyle"
        android:background="@drawable/url_bar_background"
        android:hint="Search history"
        android:drawableStart="@drawable/ic_search"
        android:drawablePadding="8dp"
        android:importantForAutofill="no" />

    <!-- Top specular separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#18FFFFFF" />

    <TextView
        android:id="@+id/empty_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_history"
        android:textColor="@color/text_tertiary"
        android:textSize="15sp"
        android:gravity="center"
        android:padding="48dp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/history_recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="32dp"
        android:clipToPadding="false" />

</LinearLayout>
