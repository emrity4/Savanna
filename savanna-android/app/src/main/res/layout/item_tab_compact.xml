<?xml version="1.0" encoding="utf-8"?>
<!--
  COMPACT mode tab card — user's exact code as the outer container.
  350×120dp, clipToOutline, @drawable/tabs_mode_c (OLED black fill, purple stroke).
-->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tabs_mode_c"
    android:layout_width="match_parent"
    android:layout_height="100dp"
    android:clipToOutline="true"
    android:background="@drawable/tabs_mode_c"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Tab info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_toStartOf="@+id/btn_close_tab"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tab_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tab_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FF8E8E93"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/btn_close_tab"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="10dp"
        android:src="@drawable/ic_close"
        android:background="@drawable/button_background"
        android:padding="4dp"
        android:scaleType="centerInside"
        android:contentDescription="Close tab" />
</RelativeLayout>
