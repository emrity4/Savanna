<?xml version="1.0" encoding="utf-8"?>
<!-- Single theme preset card in the horizontal scroller -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="96dp"
    android:layout_height="112dp"
    android:orientation="vertical"
    android:gravity="center"
    android:clickable="true"
    android:focusable="true"
    android:background="@drawable/theme_card_background"
    android:layout_marginEnd="10dp"
    android:padding="12dp">

    <!-- Big color preview circle with accent dot overlay -->
    <FrameLayout
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginBottom="8dp">

        <View
            android:id="@+id/preset_color_circle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/button_glass_circle" />

        <!-- Small accent color dot (bottom-right corner) -->
        <View
            android:id="@+id/preset_accent_dot"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/button_glass_circle" />
    </FrameLayout>

    <TextView
        android:id="@+id/preset_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textSize="11sp"
        android:maxLines="2"
        android:ellipsize="end" />

</LinearLayout>
