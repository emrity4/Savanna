<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/menu_item_background"
    android:padding="13dp"
    android:layout_marginBottom="6dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/password_favicon"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:gravity="center"
        android:textColor="#FFFFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/badge_background"
        android:layout_marginEnd="12dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/password_site"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/password_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/password_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="1dp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/btn_toggle_password"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/ic_lock"
        android:background="@drawable/button_background"
        android:padding="5dp"
        android:scaleType="centerInside"
        android:alpha="0.6"
        android:contentDescription="Show"
        android:layout_marginStart="4dp" />

    <ImageView
        android:id="@+id/btn_edit_password"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/ic_settings"
        android:background="@drawable/button_background"
        android:padding="5dp"
        android:scaleType="centerInside"
        android:alpha="0.6"
        android:contentDescription="Edit"
        android:layout_marginStart="4dp" />

    <ImageView
        android:id="@+id/btn_delete_password"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/ic_delete"
        android:background="@drawable/button_background"
        android:padding="5dp"
        android:scaleType="centerInside"
        android:alpha="0.5"
        android:contentDescription="Remove"
        android:layout_marginStart="4dp" />

</LinearLayout>
