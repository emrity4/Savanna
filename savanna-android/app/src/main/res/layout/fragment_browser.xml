<?xml version="1.0" encoding="utf-8"?>
<!--
  Savanna Browser — Liquid Glass (iOS 26) layout
  WebView fills full screen; top bar and bottom dock float on top
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Full-screen WebView underneath the floating bars -->
    <android.webkit.WebView
        android:id="@+id/web_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Thin loading progress bar at very top -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_gravity="top"
        android:progressDrawable="@drawable/progress_bar_drawable"
        android:max="100"
        android:progress="0"
        android:visibility="gone" />

    <!-- ══════════════════════════════════════
         TOP BAR — Liquid Glass URL bar
         ══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/url_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="#EE000000">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/button_background"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:contentDescription="@string/go_back"
            android:alpha="0.35" />

        <ImageView
            android:id="@+id/btn_forward"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_forward"
            android:background="@drawable/button_background"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:contentDescription="@string/go_forward"
            android:alpha="0.35"
            android:layout_marginStart="2dp" />

        <!-- Liquid Glass URL pill -->
        <EditText
            android:id="@+id/url_edit_text"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            style="@style/UrlBarStyle"
            android:background="@drawable/url_bar_background"
            android:hint="@string/search_hint"
            android:drawableStart="@drawable/ic_lock"
            android:drawablePadding="8dp"
            android:importantForAutofill="no" />

        <ImageView
            android:id="@+id/btn_reload"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_reload"
            android:background="@drawable/button_background"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:contentDescription="@string/reload" />

        <ImageView
            android:id="@+id/btn_menu"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_menu"
            android:background="@drawable/button_background"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:layout_marginStart="2dp"
            android:contentDescription="More options" />
    </LinearLayout>

    <!-- ══════════════════════════════════════
         BOTTOM DOCK — Floating Liquid Glass
         ══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bottom_bar_background"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="8dp"
        android:elevation="8dp">

        <ImageView
            android:id="@+id/btn_bookmark"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@drawable/ic_bookmark"
            android:background="@drawable/button_background"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:contentDescription="@string/bookmarks" />

        <ImageView
            android:id="@+id/btn_history"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@drawable/ic_history"
            android:background="@drawable/button_background"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:contentDescription="@string/history" />

        <FrameLayout
            android:id="@+id/btn_tabs_container"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/btn_tabs"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_tabs"
                android:background="@drawable/button_background"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:contentDescription="@string/tabs" />

            <TextView
                android:id="@+id/tab_count_badge"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="top|end"
                android:background="@drawable/badge_background"
                android:gravity="center"
                android:textColor="@color/text_primary"
                android:textSize="9sp"
                android:textStyle="bold"
                android:text="1"
                android:layout_marginTop="3dp"
                android:layout_marginEnd="9dp" />
        </FrameLayout>

        <ImageView
            android:id="@+id/btn_privacy"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@drawable/ic_shield"
            android:background="@drawable/button_background"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:contentDescription="@string/privacy_report" />

        <ImageView
            android:id="@+id/btn_settings"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@drawable/ic_settings"
            android:background="@drawable/button_background"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:contentDescription="@string/settings" />
    </LinearLayout>

</FrameLayout>
