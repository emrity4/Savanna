<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <android.webkit.WebView
            android:id="@+id/web_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <include layout="@layout/find_in_page_bar" android:layout_marginTop="24dp" />

    <FrameLayout
        android:id="@+id/tabs_mode_c"
        android:layout_width="346dp"
        android:layout_height="114dp"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="10dp"
        android:background="@drawable/tabs_mode_c_button"
        android:elevation="12dp"
        android:clipToOutline="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <FrameLayout
                android:id="@+id/url_bar_search"
                android:layout_width="326dp"
                android:layout_height="44dp"
                android:layout_marginTop="9dp"
                android:clipToOutline="true">

                <ImageView
                    android:id="@+id/url_lock"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="14dp"
                    android:src="@drawable/ic_lock"
                    android:scaleType="fitCenter"
                    android:visibility="gone" />

                <EditText
                    android:id="@+id/url_edit_text"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="@string/search_hint"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:paddingStart="36dp"
                    android:paddingEnd="36dp"
                    android:importantForAutofill="no"
                    android:inputType="textNoSuggestions"
                    android:imeOptions="actionSearch"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <ImageView
                    android:id="@+id/url_reader"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="32dp"
                    android:src="@drawable/ic_reader"
                    android:scaleType="fitCenter"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/url_reload"
                    android:layout_width="15dp"
                    android:layout_height="18dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_reload"
                    android:scaleType="fitCenter"
                    android:visibility="gone" />
            </FrameLayout>

            <ProgressBar
                android:id="@+id/progress_bar"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="326dp"
                android:layout_height="2dp"
                android:progressDrawable="@drawable/progress_bar_drawable"
                android:max="100"
                android:progress="0"
                android:indeterminate="false"
                android:visibility="gone" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:id="@+id/bottom_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp">

                <Space
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="24dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_back"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/go_back"
                    android:alpha="0.5" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/btn_forward"
                    android:layout_width="24dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_forward"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/go_forward"
                    android:alpha="0.5" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/btn_share"
                    android:layout_width="24dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_share"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/share" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/btn_tabs"
                    android:layout_width="24dp"
                    android:layout_height="48dp"
                    android:gravity="top|center_horizontal"
                    android:paddingTop="4dp"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:text="1"
                    android:contentDescription="@string/tabs" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/btn_bookmark"
                    android:layout_width="24dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_bookmark"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/bookmarks" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/btn_settings"
                    android:layout_width="24dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_settings"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/settings" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- Compact Mode: top search bar -->
    <FrameLayout
        android:id="@+id/top_search_bar"
        android:layout_width="370dp"
        android:layout_height="44dp"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="86dp"
        android:elevation="12dp"
        android:clipToOutline="true"
        android:visibility="gone">

        <EditText
            android:id="@+id/compact_url_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@null"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:importantForAutofill="no"
            android:inputType="textNoSuggestions"
            android:maxLines="1"
            android:ellipsize="end" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="14dp"
            android:src="@drawable/ic_lock"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <ImageView
            android:layout_width="15dp"
            android:layout_height="18dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_reload"
            android:scaleType="fitCenter" />
    </FrameLayout>

    <!-- Compact Mode: bottom toolbar -->
    <LinearLayout
        android:id="@+id/compact_bottom_bar"
        android:layout_width="346dp"
        android:layout_height="48dp"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="12dp"
        android:clipToOutline="true"
        android:visibility="gone">

        <Space android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" />
        <ImageView android:id="@+id/compact_btn_back" android:layout_width="24dp" android:layout_height="48dp" android:src="@drawable/ic_back" android:scaleType="centerInside" android:alpha="0.5" />
        <Space android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" />
        <ImageView android:id="@+id/compact_btn_forward" android:layout_width="24dp" android:layout_height="48dp" android:src="@drawable/ic_forward" android:scaleType="centerInside" android:alpha="0.5" />
        <Space android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" />
        <ImageView android:id="@+id/compact_btn_share" android:layout_width="24dp" android:layout_height="48dp" android:src="@drawable/ic_share" android:scaleType="centerInside" />
        <Space android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" />
        <TextView android:id="@+id/compact_btn_tabs" android:layout_width="24dp" android:layout_height="48dp" android:gravity="top|center_horizontal" android:paddingTop="4dp" android:textColor="@color/text_primary" android:textSize="11sp" android:textStyle="bold" android:text="1" />
        <Space android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" />
        <ImageView android:id="@+id/compact_btn_bookmark" android:layout_width="24dp" android:layout_height="48dp" android:src="@drawable/ic_bookmark" android:scaleType="centerInside" />
        <Space android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" />
        <ImageView android:id="@+id/compact_btn_settings" android:layout_width="24dp" android:layout_height="48dp" android:src="@drawable/ic_settings" android:scaleType="centerInside" />
        <Space android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/url_scroll_pill"
        android:layout_width="142dp"
        android:layout_height="46dp"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="16dp"
        android:background="@drawable/tabs_mode_c_button"
        android:elevation="12dp"
        android:clipToOutline="true"
        android:visibility="gone">

        <TextView
            android:id="@+id/url_domain_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </FrameLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/url_suggestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="128dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/safari_bottom_bar"
        android:elevation="10dp"
        android:clipToPadding="true"
        android:paddingVertical="8dp"
        android:visibility="gone"
        android:overScrollMode="never"
        android:nestedScrollingEnabled="false" />

    <HorizontalScrollView
        android:id="@+id/url_actions_strip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="128dp"
        android:background="#E8000000"
        android:clipToPadding="false"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="7dp"
        android:paddingBottom="9dp"
        android:elevation="6dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chip_clear"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Clear"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_copy"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Copy Link"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_paste"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Paste"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_paste_go"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Paste &amp; Go"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_share_link"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Share Link"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_find"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Find"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_reload"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Reload"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_history"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/history"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_back"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/nav_back"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_forward"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/nav_forward"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_date"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/pick_date"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_time"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/pick_time"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background" />

        </LinearLayout>
    </HorizontalScrollView>



</FrameLayout>
