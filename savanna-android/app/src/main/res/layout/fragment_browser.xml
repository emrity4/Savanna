<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <android.webkit.WebView
            android:id="@+id/web_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <include layout="@layout/find_in_page_bar" />

    <ProgressBar
        android:id="@+id/progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_gravity="top"
        android:progressDrawable="@drawable/progress_bar_drawable"
        android:max="100"
        android:progress="0"
        android:indeterminate="false"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/safari_bottom_bar"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="10dp"
        android:elevation="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_back"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:contentDescription="@string/go_back"
                android:alpha="0.5" />

            <ImageView
                android:id="@+id/btn_forward"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_forward"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:contentDescription="@string/go_forward"
                android:alpha="0.5"
                android:layout_marginStart="2dp" />

            <ImageView
                android:id="@+id/btn_share"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_share"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:contentDescription="@string/share"
                android:layout_marginStart="2dp" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/tabs_mode_b"
                android:clipToOutline="true">

                <EditText
                    android:id="@+id/url_edit_text"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="@string/search_hint"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:paddingStart="36dp"
                    android:paddingEnd="36dp"
                    android:importantForAutofill="no"
                    android:inputType="textNoSuggestions"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <ImageView
                    android:id="@+id/url_lock"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_lock"
                    android:scaleType="fitCenter"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/url_reader"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/ic_reader"
                    android:scaleType="fitCenter"
                    android:visibility="gone" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btn_tabs_container"
                android:layout_width="36dp"
                android:layout_height="36dp">

                <ImageView
                    android:id="@+id/btn_tabs"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_tabs"
                    android:padding="7dp"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/tabs" />

                <TextView
                    android:id="@+id/tab_count_badge"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="0dp"
                    android:layout_marginEnd="1dp"
                    android:background="@drawable/badge_background"
                    android:gravity="center"
                    android:textColor="@color/text_primary"
                    android:textSize="7sp"
                    android:textStyle="bold"
                    android:text="1" />
            </FrameLayout>

            <ImageView
                android:id="@+id/btn_bookmark"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_bookmark"
                android:padding="7dp"
                android:scaleType="centerInside"
                android:contentDescription="@string/bookmarks"
                android:layout_marginStart="2dp" />

            <ImageView
                android:id="@+id/btn_settings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_settings"
                android:padding="7dp"
                android:scaleType="centerInside"
                android:contentDescription="@string/settings"
                android:layout_marginStart="2dp" />

        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/url_suggestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="64dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/safari_bottom_bar"
        android:elevation="10dp"
        android:clipToPadding="true"
        android:paddingVertical="8dp"
        android:visibility="gone"
        android:overScrollMode="never"
        android:nestedScrollingEnabled="false" />

    <HorizontalScrollView
        android:id="@+id/url_actions_strip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="64dp"
        android:background="#E8000000"
        android:clipToPadding="false"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="7dp"
        android:paddingBottom="9dp"
        android:elevation="6dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chip_clear"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Clear"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_copy"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Copy Link"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_paste"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Paste"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_paste_go"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Paste &amp; Go"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_share_link"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Share Link"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_find"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Find"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_reload"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Reload"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_history"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/history"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_back"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/nav_back"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_forward"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/nav_forward"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_date"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/pick_date"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_time"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="@string/pick_time"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/action_chip_background" />

        </LinearLayout>
    </HorizontalScrollView>

</FrameLayout>
