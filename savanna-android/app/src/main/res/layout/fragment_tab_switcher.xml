<?xml version="1.0" encoding="utf-8"?>
<!--
  Tab switcher sheet — used as a BottomSheetDialogFragment.
  Root has match_parent height; BottomSheetBehavior controls peek/expand.
  Background is our glass drawable (transparent to the dialog's blur-behind).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/sheet_background">

    <!-- Drag handle pill — indicates the sheet is draggable -->
    <View
        android:layout_width="44dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/pill_indicator" />

    <!-- Header row: Tabs title ·  New Tab  ·  Close -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:paddingStart="22dp"
        android:paddingEnd="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:text="@string/tabs"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_new_tab"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_add"
                android:background="@drawable/button_glass_circle"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:contentDescription="@string/new_tab" />

            <ImageView
                android:id="@+id/btn_close_tab_switcher"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_close"
                android:background="@drawable/button_glass_circle"
                android:padding="11dp"
                android:scaleType="centerInside"
                android:layout_marginStart="6dp"
                android:contentDescription="@string/done" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Glass divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#38FFFFFF"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" />

    <!-- Tab list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tabs_recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="16dp"
        android:paddingBottom="40dp"
        android:clipToPadding="false" />

</LinearLayout>
