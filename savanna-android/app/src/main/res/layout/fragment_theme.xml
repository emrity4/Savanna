<?xml version="1.0" encoding="utf-8"?>
<!-- Advanced Theme / Appearance sheet -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Glass top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#EE000000"
        android:paddingBottom="10dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="22dp"
            android:paddingEnd="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:text="Appearance"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <ImageView
                android:id="@+id/btn_close_theme"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:src="@drawable/ic_close"
                android:background="@drawable/button_background"
                android:padding="9dp"
                android:scaleType="centerInside"
                android:contentDescription="Done" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#22FFFFFF" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="56dp">

            <!-- ── COLOR THEME ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="COLOR THEME"
                android:textColor="@color/purple_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/theme_presets_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingEnd="8dp" />
            </HorizontalScrollView>

            <!-- ── ACCENT COLOR ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ACCENT COLOR"
                android:textColor="@color/purple_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/accent_colors_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="4dp"
                    android:paddingEnd="8dp"
                    android:gravity="center_vertical" />
            </HorizontalScrollView>

            <!-- ── URL BAR STYLE ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="URL BAR STYLE"
                android:textColor="@color/purple_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="28dp">

                <TextView
                    android:id="@+id/style_glass"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="Glass"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/action_chip_background"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/style_frosted"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="Frosted"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/action_chip_background"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/style_solid"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="Solid"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/action_chip_background" />
            </LinearLayout>

            <!-- ── TEXT SIZE ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TEXT SIZE"
                android:textColor="@color/purple_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="28dp">

                <TextView
                    android:id="@+id/size_small"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="Small"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:background="@drawable/action_chip_background"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/size_medium"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="Medium"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:background="@drawable/action_chip_background"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/size_large"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="Large"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:background="@drawable/action_chip_background" />
            </LinearLayout>

            <!-- ── BEHAVIOUR ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BEHAVIOUR"
                android:textColor="@color/purple_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="10dp"
                android:layout_marginStart="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_background"
                android:orientation="vertical"
                android:padding="2dp"
                android:layout_marginBottom="24dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Auto-hide Bars"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@android:id/title"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true"
                        android:layout_marginTop="18dp"
                        android:text="Toolbar fades while scrolling"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_auto_hide_bars"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
